#!/usr/bin/env python
"""Printing slower-downer. Results not guaranteed outside ASCII."""

import time
from sys import argv, stdin, stdout

rate = int(argv[1]) if len(argv) > 1 else 300
delay = 1.0 / (rate / 7)  # 7 bits for ASCII

try:
  for line in stdin:
    for c in line:
      stdout.write(c)
      stdout.flush()
      time.sleep(delay)
  stdout.write("\n")
  stdout.flush()
except KeyboardInterrupt:
  stdout.write("\n")
  stdout.flush()
