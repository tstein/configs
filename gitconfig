[user]
  name = Ted Stein
  email = me@tedstein.net
[core]
  fsmonitor = true
  whitespace = tab-in-indent,tabwidth=2
[color]
  ui = auto
[advice]
  commitBeforeMerge = false
  detachedHead = false
  implicitIdentity = false
  pushNonFastForward = false
  resolveConflict = false
  statusHints = false

[alias]
  br = branch -vv
  gl = log --graph --pretty=format:\
'%Cgreen%h %Cred(%cr)%Creset -%C(yellow)%d%Creset %s %Cblue<%an>%Creset'
  st = status --branch --short

[branch]
  autosetuprebase = always
[commit]
  verbose = true
[diff]
  indentHeuristic = on
[fetch]
  prune = true
[init]
  defaultBranch = main
[push]
  default = simple
[rebase]
  autosquash = true
